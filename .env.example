# ─── Evomi Credentials ───────────────────────────────────────────────────────
# API key for Evomi REST API (used for balance & stats when available)
EVOMI_API_KEY=your_evomi_api_key_here

# Dashboard login credentials (used only when Playwright scraping is needed)
EVOMI_USERNAME=your_evomi_email@example.com
EVOMI_PASSWORD=your_evomi_password_here

# ─── Slack ────────────────────────────────────────────────────────────────────
# Incoming Webhook URL — used to POST scheduled notifications
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx

# Bot OAuth token — needed only when running the slash-command server (src/server.js)
# Scope required: chat:write
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing secret — used to verify that slash-command requests come from Slack
# Found in: Slack app settings → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=your_signing_secret_here

# ─── Server ───────────────────────────────────────────────────────────────────
# Port for the slash-command HTTP server (default: 3000)
PORT=3000
